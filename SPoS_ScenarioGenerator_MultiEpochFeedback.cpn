        <block id="ID500053">
          <id>Crypto and SPoS Functions</id>
          <ml id="ID500054">val MIN_STAKE = 10;
val OWNER_STAKE_CAP = 1000;
val MOBILE_FITNESS_MIN = 28;
val ATTACK_THRESHOLD = 70;
val EPOCH = 1;
val HASH_MOD = 7919;
val VRF_BASE = 35;
val VRF_MAX_THRESHOLD = 95;
val MIN_COMMITTEE = 2;
val MAX_VRF_RERUNS = 8;

fun clamp0(x:int) = if x &lt; 0 then 0 else x;
fun capOwnerStake(s:int) = if s &gt; OWNER_STAKE_CAP then OWNER_STAKE_CAP else s;
fun posMod(x:int, m:int) = if x &lt; 0 then (x mod m) + m else x mod m;
fun mix(a:int, b:int) = posMod((a * 127 + b * 257 + 1049), HASH_MOD);
fun hash2(a:int, b:int) = mix(a,b);
fun hash3(a:int, b:int, c:int) = hash2(hash2(a,b),c);
fun hash4(a:int, b:int, c:int, d:int) = hash2(hash3(a,b,c),d);

fun privateKey(vid:int) = posMod(vid * 331 + 97, HASH_MOD);
fun publicKey(vid:int) = hash2(privateKey(vid), 31);
fun publicKeyMetric(vs:VIDxSTAKE) = let val (vid,_) = vs in (vid, publicKey(vid)) end;
fun signMessage(vid:int, msgHash:int) = hash3(privateKey(vid), msgHash, vid);
fun makeSignature(vid:int, msgHash:int) = (vid, msgHash, signMessage(vid,msgHash));
fun verifySignature(sg:SIGNATURE) = let val (vid,msg,value) = sg in value = signMessage(vid,msg) end;

fun sqrtApprox(s:int) =
  if s &lt;= 0 then 0
  else if s &lt;= 25 then 5
  else if s &lt;= 100 then 10
  else if s &lt;= 225 then 15
  else if s &lt;= 400 then 20
  else if s &lt;= 625 then 25
  else if s &lt;= 900 then 30
  else 31;

fun stakeOfVID(vid:int) =
  if vid = 1 then 100
  else if vid = 2 then 200
  else if vid = 3 then 5000
  else if vid = 4 then 30
  else if vid = 5 then 80
  else if vid = 6 then 70
  else 10;

fun ownerOf(vid:int) = if vid = 1 orelse vid = 2 then 1 else vid;
fun ownerTotalStake(vid:int) = if ownerOf(vid) = 1 then 300 else stakeOfVID(vid);
fun ownerGroupSize(vid:int) = if ownerOf(vid) = 1 then 2 else 1;
fun ownerAdjustedStakePower(vid:int) = sqrtApprox(capOwnerStake(ownerTotalStake(vid))) div ownerGroupSize(vid);
fun roundsNotSelected(vid:int) = if vid = 4 then 5 else if vid = 5 then 4 else if vid = 6 then 3 else 1;
fun fairnessBoost(vid:int) = roundsNotSelected(vid) * 3;
fun ownerApproxStake(vid:int, stake:int) = if ownerOf(vid) = 1 then stake * ownerGroupSize(vid) else stake;
fun ownerAdjustedStakePowerFromStake(vid:int, stake:int) = sqrtApprox(capOwnerStake(ownerApproxStake(vid,stake))) div ownerGroupSize(vid);
fun ownerScore(vs:VIDxSTAKE) = let val (vid,stake) = vs in (vid, ownerAdjustedStakePowerFromStake(vid,stake) + fairnessBoost(vid)) end;

fun battery(vid:int) = if vid = 4 then 20 else if vid = 2 then 55 else 80;
fun bandwidth(vid:int) = if vid = 4 then 25 else if vid = 6 then 50 else 70;
fun latency(vid:int) = if vid = 4 then 90 else if vid = 2 then 65 else 40;
fun availability(vid:int) = if vid = 4 then 35 else if vid = 6 then 70 else 85;
fun capacity(vid:int) = if vid = 4 then 30 else if vid = 2 then 55 else 75;
fun edgeConnectivity(vid:int) = if vid = 4 then 25 else if vid = 6 then 60 else 80;
fun latencyScore(vid:int) = if latency(vid) &gt; 100 then 0 else 100 - latency(vid);
fun mobileFitness(vid:int) = (battery(vid) + bandwidth(vid) + latencyScore(vid) + availability(vid) + capacity(vid) + edgeConnectivity(vid)) div 6;
fun mobileFitnessFromStake(vid:int, stake:int) = if vid = 4 orelse stake &lt;= 35 then 26 else mobileFitness(vid);
fun mobileScore(vs:VIDxSTAKE) = let val (vid,stake) = vs in (vid, mobileFitnessFromStake(vid,stake)) end;
fun mobileOK(msc:VIDxSCORE) = let val (_,s) = msc in s &gt;= MOBILE_FITNESS_MIN end;

fun attackLevel(vid:int) = if vid = 3 then 90 else if vid = 4 then 25 else if vid = 2 then 10 else 0;
fun attackPenalty(vid:int) = attackLevel(vid) div 2;
fun attackLevelFromStake(vid:int, stake:int) = if vid = 3 orelse stake &gt;= 4500 then 90 else if stake &lt;= 35 then 25 else attackLevel(vid);
fun attackPenaltyFromStake(vid:int, stake:int) = attackLevelFromStake(vid,stake) div 2;
fun attackScore(vs:VIDxSTAKE) = let val (vid,stake) = vs in (vid, attackPenaltyFromStake(vid,stake)) end;
fun maliciousScore(asc:VIDxSCORE) = let val (_,p) = asc in p * 2 &gt;= ATTACK_THRESHOLD end;

fun vidOfScore(sc:VIDxSCORE) = let val (vid,_) = sc in vid end;
fun scoreValue(sc:VIDxSCORE) = let val (_,s) = sc in s end;
fun sameVID2(a:VIDxSCORE,b:VIDxSCORE) = vidOfScore(a)=vidOfScore(b);
fun sameVID3(a:VIDxSCORE,b:VIDxSCORE,c:VIDxSCORE) = sameVID2(a,b) andalso sameVID2(a,c);
fun mergeScore(osc:VIDxSCORE, msc:VIDxSCORE, asc:VIDxSCORE) =
  let val vid = vidOfScore(osc)
      val s = scoreValue(osc) + scoreValue(msc) - scoreValue(asc)
  in (vid, clamp0(s)) end;
fun selectionMetric(sc:VIDxSCORE) = let val (vid,s)=sc in (vid,s) end;
fun quarantineMetric(sc:VIDxSCORE) = let val (vid,s)=sc in (100+vid,s) end;
fun lowFitnessMetric(sc:VIDxSCORE) = let val (vid,s)=sc in (200+vid,s) end;
fun eligible(vs:VIDxSTAKE) = let val (_,stake) = vs in stake &gt;= MIN_STAKE end;

fun toShard1(sc:VIDxSCORE) = (1, vidOfScore(sc));
fun toShard2(sc:VIDxSCORE) = (2, vidOfScore(sc));
fun toAudit(sc:VIDxSCORE) = (99, vidOfScore(sc));
fun sidOfCommittee(cm:SIDxVID) = let val (sid,_) = cm in sid end;
fun vidOfCommittee(cm:SIDxVID) = let val (_,vid) = cm in vid end;

fun makeVRFProof(cm:SIDxVID, seed:int) =
  let val (sid,vid) = cm
      val msg = hash4(seed, sid, vid, EPOCH)
      val proof = signMessage(vid,msg)
      val out = posMod(hash3(proof, seed, sid), 100)
  in (sid,vid,seed,out,proof) end;
fun proofToCommittee(pf:VRFPROOF) = let val (sid,vid,_,_,_) = pf in (sid,vid) end;
fun vrfOutput(pf:VRFPROOF) = let val (_,_,_,out,_) = pf in out end;
fun verifyVRFProof(pf:VRFPROOF) =
  let val (sid,vid,seed,out,proof) = pf
      val msg = hash4(seed, sid, vid, EPOCH)
  in proof = signMessage(vid,msg) andalso out = posMod(hash3(proof, seed, sid), 100) end;
fun committeeThreshold(cm:SIDxVID) =
  let val (_,vid) = cm
      val base = VRF_BASE + ownerAdjustedStakePower(vid) + fairnessBoost(vid)
  in if base &gt; VRF_MAX_THRESHOLD then VRF_MAX_THRESHOLD else base end;
fun acceptVRF(pf:VRFPROOF) = verifyVRFProof(pf) andalso vrfOutput(pf) &lt; committeeThreshold(proofToCommittee(pf));
fun rejectVRF(pf:VRFPROOF) = verifyVRFProof(pf) andalso not(acceptVRF(pf));
fun nextSeed(seed:int) = seed + 1;
fun recoveryAccept(pf:VRFPROOF) = verifyVRFProof(pf);
fun vrfMetric(pf:VRFPROOF) = let val (sid,vid,seed,out,_) = pf in (sid, vid*1000 + seed*10 + out) end;
fun rejectMetric(pf:VRFPROOF) = let val (sid,vid,seed,out,_) = pf in (10+sid, vid*1000 + seed*10 + out) end;
fun recoveryMetric(cm:SIDxVID, seed:int) = let val (sid,vid)=cm in (20+sid, vid*100 + nextSeed(seed)) end;

fun shardOfTxID(txid:int) = if txid mod 2 = 1 then 1 else 2;
fun txCommit(txid:int) = (txid, shardOfTxID(txid), hash3(txid, shardOfTxID(txid), EPOCH));
fun cmtTxID(cmt:COMMITMENT) = let val (txid,_,_) = cmt in txid end;
fun cmtShard(cmt:COMMITMENT) = let val (_,sid,_) = cmt in sid end;
fun cmtToShardTx(cmt:COMMITMENT) = (cmtShard(cmt), cmtTxID(cmt));
fun cmtIsShard(cmt:COMMITMENT, sid:int) = cmtShard(cmt) = sid;
fun txRouteMetric(cmt:COMMITMENT) = let val (txid,sid,h)=cmt in (sid, txid + h) end;

fun committeeDistinct(a:SIDxVID,b:SIDxVID) =
  let val (s1,v1)=a
      val (s2,v2)=b
  in s1=s2 andalso v1&lt;&gt;v2 end;
fun sameShardPair(a:SIDxVID,b:SIDxVID,sid:int) = sidOfCommittee(a)=sid andalso sidOfCommittee(b)=sid andalso committeeDistinct(a,b);
fun makeBlockFromTx(tx:SIDxTX, cm:SIDxVID) =
  let val (sid,txid)=tx
      val (_,vid)=cm
  in (sid,txid,vid) end;
fun blockShard(blk:BLOCK) = let val (sid,_,_) = blk in sid end;
fun blockHash(blk:BLOCK) = let val (sid,bid,vid)=blk in hash4(sid,bid,vid,EPOCH) end;
fun blockHashMetric(blk:BLOCK) = let val (sid,_,_) = blk in (30+sid, blockHash(blk)) end;
fun certificateFromQuorum(blk:BLOCK, cm1:SIDxVID, cm2:SIDxVID) =
  let val (sid,bid,_) = blk
      val (_,v1) = cm1
      val (_,v2) = cm2
      val h = hash4(blockHash(blk), v1, v2, sid)
  in (sid,bid,h) end;
fun finalityMetric(cert:CERT) = let val (sid,bid,h)=cert in (40+sid, bid+h) end;
fun receiptFromCert(cert:CERT) = let val (sid,bid,h)=cert in (sid, hash3(h,bid,11)) end;
fun rewardFromCert(cert:CERT) = let val (sid,bid,h)=cert in (sid, 10 + (h mod 7)) end;
fun baselineMetric(seed:int) = (1,77);
fun rrMetric(seed:int) = (2,0);
fun proposedMetric(seed:int) = (3,22);

fun proposerOfBlock(blk:BLOCK) = let val (_,_,vid)=blk in vid end;
fun certificateRewardPool(cert:CERT) = let val (_,_,h)=cert in 12 + (h mod 9) end;
fun mobileRewardBonus(vid:int) = if mobileFitness(vid) &gt;= 70 then 2 else if mobileFitness(vid) &gt;= 60 then 1 else 0;
fun lowStakeRewardBonus(vid:int) = if stakeOfVID(vid) &lt;= 100 then 1 else 0;
fun proposerRewardAmount(cert:CERT, vid:int) = (certificateRewardPool(cert) div 2) + mobileRewardBonus(vid) + lowStakeRewardBonus(vid);
fun voterRewardAmount(cert:CERT, vid:int) = (certificateRewardPool(cert) div 4) + mobileRewardBonus(vid);
fun proposerValidatorReward(blk:BLOCK, cert:CERT) =
  let val vid = proposerOfBlock(blk)
  in (vid, proposerRewardAmount(cert,vid)) end;
fun voterValidatorReward(cm:SIDxVID, cert:CERT) =
  let val (_,vid)=cm
  in (vid, voterRewardAmount(cert,vid)) end;
fun validatorRewardAuditMetric(m:METRIC) = let val (vid,r)=m in (300+vid,r) end;
fun rewardPoolAuditMetric(cert:CERT) = let val (sid,bid,h)=cert in (60+sid, certificateRewardPool(cert)*100 + (h mod 100)) end;

fun rewardVid(m:METRIC) = let val (vid,_) = m in vid end;
fun rewardAmount(m:METRIC) = let val (_,r) = m in r end;
fun sameVIDRewardBalance(m:METRIC, vs:VIDxSTAKE) =
  let val (vid,_) = m
      val (bvid,_) = vs
  in vid = bvid end;
fun updateStakeWithReward(vs:VIDxSTAKE, m:METRIC) =
  let val (vid,bal) = vs
      val (_,r) = m
  in (vid, bal + r) end;
fun ownerRewardShare(m:METRIC) = let val (vid,r)=m in (ownerOf(vid), r) end;
fun validatorRewardShare(m:METRIC) = m;
fun nextEpochStakeAuditMetric(vs:VIDxSTAKE, m:METRIC) =
  let val (vid,bal) = updateStakeWithReward(vs,m)
  in (400+vid, bal) end;
fun ownerRewardAuditMetric(m:METRIC) = let val (oid,r)=ownerRewardShare(m) in (500+oid,r) end;
fun rewardConcentrationAuditMetric(m:METRIC) = let val (vid,r)=m in (600+vid,r) end;

fun rawStakeGiniScaled(seed:int) = (701,84);
fun activePowerGiniScaled(seed:int) = (702,13);
fun rawStakeNakamoto(seed:int) = (711,1);
fun activeValidatorNakamoto(seed:int) = (712,2);
fun rawStakeHHIScaled(seed:int) = (721,83);
fun activeRewardHHIScaled(seed:int) = (722,25);
fun decentralizationMetricBundle(seed:int) =
  1`rawStakeGiniScaled(seed)++
  1`activePowerGiniScaled(seed)++
  1`rawStakeNakamoto(seed)++
  1`activeValidatorNakamoto(seed)++
  1`rawStakeHHIScaled(seed)++
  1`activeRewardHHIScaled(seed);



(* Scenario-generator and multi-epoch experiment support.  RUNCFG fields:
   (runID, epochID, scenarioID, nValidators, nTxs, maliciousMode, weakMobileMode, seed)
   Scenario IDs: 1 balanced, 2 skewed stake, 3 owner stake-splitting, 4 reference high-stake malicious,
                 5 mobile-weak validators, 6 mixed/randomized. *)
fun cfgRun(c:RUNCFG) = let val (r,_,_,_,_,_,_,_) = c in r end;
fun cfgEpoch(c:RUNCFG) = let val (_,e,_,_,_,_,_,_) = c in e end;
fun cfgScenario(c:RUNCFG) = let val (_,_,s,_,_,_,_,_) = c in s end;
fun cfgNValidators(c:RUNCFG) = let val (_,_,_,nv,_,_,_,_) = c in nv end;
fun cfgNTxs(c:RUNCFG) = let val (_,_,_,_,nt,_,_,_) = c in nt end;
fun cfgMaliciousMode(c:RUNCFG) = let val (_,_,_,_,_,am,_,_) = c in am end;
fun cfgWeakMode(c:RUNCFG) = let val (_,_,_,_,_,_,wm,_) = c in wm end;
fun cfgSeed(c:RUNCFG) = let val (_,_,_,_,_,_,_,sd) = c in sd end;

fun deterministicNoise(c:RUNCFG, vid:int) = posMod(cfgRun(c)*97 + cfgEpoch(c)*43 + cfgScenario(c)*31 + vid*53, 97);
fun genStake(c:RUNCFG, vid:int) =
  let val s = cfgScenario(c)
      val noise = deterministicNoise(c,vid)
  in
    if s = 1 then 100 + noise
    else if s = 2 then (if vid = 3 then 5000 + noise else 30 + (noise mod 180))
    else if s = 3 then (if vid = 1 orelse vid = 2 then 2500 + noise else 40 + (noise mod 160))
    else if s = 4 then
      (if vid = 1 then 100 else if vid = 2 then 200 else if vid = 3 then 5000 else if vid = 4 then 30 else if vid = 5 then 80 else if vid = 6 then 70 else 10 + noise)
    else if s = 5 then (if vid = 4 orelse vid = 5 then 25 + (noise mod 10) else 80 + noise)
    else 10 + posMod(cfgRun(c)*vid*37 + cfgEpoch(c)*19 + noise, 5000)
  end;

fun oneValidator(c:RUNCFG, vid:int) = if vid &lt;= cfgNValidators(c) then 1`(vid, genStake(c,vid)) else empty;
fun genValidators(c:RUNCFG) =
  oneValidator(c,1)++oneValidator(c,2)++oneValidator(c,3)++oneValidator(c,4)++oneValidator(c,5)++oneValidator(c,6)++
  oneValidator(c,7)++oneValidator(c,8)++oneValidator(c,9)++oneValidator(c,10)++oneValidator(c,11)++oneValidator(c,12);

fun genTxID(c:RUNCFG, idx:int) = 100 + ((cfgRun(c)-1)*1000) + ((cfgEpoch(c)-1)*100) + idx;
fun oneTx(c:RUNCFG, idx:int) = if idx &lt;= cfgNTxs(c) then 1`genTxID(c,idx) else empty;
fun genMobileTxs(c:RUNCFG) =
  oneTx(c,1)++oneTx(c,2)++oneTx(c,3)++oneTx(c,4)++oneTx(c,5)++oneTx(c,6)++oneTx(c,7)++oneTx(c,8)++oneTx(c,9)++oneTx(c,10)++
  oneTx(c,11)++oneTx(c,12)++oneTx(c,13)++oneTx(c,14)++oneTx(c,15)++oneTx(c,16)++oneTx(c,17)++oneTx(c,18)++oneTx(c,19)++oneTx(c,20)++
  oneTx(c,21)++oneTx(c,22)++oneTx(c,23)++oneTx(c,24)++oneTx(c,25)++oneTx(c,26)++oneTx(c,27)++oneTx(c,28)++oneTx(c,29)++oneTx(c,30)++
  oneTx(c,31)++oneTx(c,32)++oneTx(c,33)++oneTx(c,34)++oneTx(c,35)++oneTx(c,36)++oneTx(c,37)++oneTx(c,38)++oneTx(c,39)++oneTx(c,40)++
  oneTx(c,41)++oneTx(c,42)++oneTx(c,43)++oneTx(c,44)++oneTx(c,45)++oneTx(c,46)++oneTx(c,47)++oneTx(c,48)++oneTx(c,49)++oneTx(c,50);

fun genEpochSeed(c:RUNCFG) = cfgSeed(c) + ((cfgRun(c)-1)*13) + ((cfgEpoch(c)-1)*17);
fun genBaselineSeed(c:RUNCFG) = cfgScenario(c);
fun scenarioRunMetric(c:RUNCFG) = (1000 + cfgScenario(c), cfgRun(c)*100 + cfgEpoch(c));
fun scenarioValidatorCountMetric(c:RUNCFG) = (1010, cfgNValidators(c));
fun scenarioTxCountMetric(c:RUNCFG) = (1011, cfgNTxs(c));
fun scenarioSeedMetric(c:RUNCFG) = (1012, genEpochSeed(c));
fun genScenarioRunLog(c:RUNCFG) =
  1`scenarioRunMetric(c)++1`scenarioValidatorCountMetric(c)++1`scenarioTxCountMetric(c)++1`scenarioSeedMetric(c);

fun slashPenalty(vid:int) = if vid = 3 then 50 else if vid = 4 then 5 else 10;
fun doubleProposalEvidence(sc:VIDxSCORE) = let val (vid,s)=sc in (800+vid,s) end;
fun invalidVoteEvidence(sc:VIDxSCORE) = let val (vid,s)=sc in (820+vid,s) end;
fun offlineMobileEvidence(sc:VIDxSCORE) = let val (vid,s)=sc in (840+vid,s) end;
fun doubleProposalSlash(sc:VIDxSCORE) = let val (vid,_) = sc in (900+vid, slashPenalty(vid)) end;
fun invalidVoteSlash(sc:VIDxSCORE) = let val (vid,_) = sc in (920+vid, slashPenalty(vid)) end;
fun offlineMobilePenalty(sc:VIDxSCORE) = let val (vid,_) = sc in (940+vid, slashPenalty(vid)) end;
            <layout>val MIN_STAKE = 10;
val OWNER_STAKE_CAP = 1000;
val MOBILE_FITNESS_MIN = 28;
val ATTACK_THRESHOLD = 70;
val EPOCH = 1;
val HASH_MOD = 7919;
val VRF_BASE = 35;
val VRF_MAX_THRESHOLD = 95;
val MIN_COMMITTEE = 2;
val MAX_VRF_RERUNS = 8;

fun clamp0(x:int) = if x &lt; 0 then 0 else x;
fun capOwnerStake(s:int) = if s &gt; OWNER_STAKE_CAP then OWNER_STAKE_CAP else s;
fun posMod(x:int, m:int) = if x &lt; 0 then (x mod m) + m else x mod m;
fun mix(a:int, b:int) = posMod((a * 127 + b * 257 + 1049), HASH_MOD);
fun hash2(a:int, b:int) = mix(a,b);
fun hash3(a:int, b:int, c:int) = hash2(hash2(a,b),c);
fun hash4(a:int, b:int, c:int, d:int) = hash2(hash3(a,b,c),d);

fun privateKey(vid:int) = posMod(vid * 331 + 97, HASH_MOD);
fun publicKey(vid:int) = hash2(privateKey(vid), 31);
fun publicKeyMetric(vs:VIDxSTAKE) = let val (vid,_) = vs in (vid, publicKey(vid)) end;
fun signMessage(vid:int, msgHash:int) = hash3(privateKey(vid), msgHash, vid);
fun makeSignature(vid:int, msgHash:int) = (vid, msgHash, signMessage(vid,msgHash));
fun verifySignature(sg:SIGNATURE) = let val (vid,msg,value) = sg in value = signMessage(vid,msg) end;

fun sqrtApprox(s:int) =
  if s &lt;= 0 then 0
  else if s &lt;= 25 then 5
  else if s &lt;= 100 then 10
  else if s &lt;= 225 then 15
  else if s &lt;= 400 then 20
  else if s &lt;= 625 then 25
  else if s &lt;= 900 then 30
  else 31;

fun stakeOfVID(vid:int) =
  if vid = 1 then 100
  else if vid = 2 then 200
  else if vid = 3 then 5000
  else if vid = 4 then 30
  else if vid = 5 then 80
  else if vid = 6 then 70
  else 10;

fun ownerOf(vid:int) = if vid = 1 orelse vid = 2 then 1 else vid;
fun ownerTotalStake(vid:int) = if ownerOf(vid) = 1 then 300 else stakeOfVID(vid);
fun ownerGroupSize(vid:int) = if ownerOf(vid) = 1 then 2 else 1;
fun ownerAdjustedStakePower(vid:int) = sqrtApprox(capOwnerStake(ownerTotalStake(vid))) div ownerGroupSize(vid);
fun roundsNotSelected(vid:int) = if vid = 4 then 5 else if vid = 5 then 4 else if vid = 6 then 3 else 1;
fun fairnessBoost(vid:int) = roundsNotSelected(vid) * 3;
fun ownerApproxStake(vid:int, stake:int) = if ownerOf(vid) = 1 then stake * ownerGroupSize(vid) else stake;
fun ownerAdjustedStakePowerFromStake(vid:int, stake:int) = sqrtApprox(capOwnerStake(ownerApproxStake(vid,stake))) div ownerGroupSize(vid);
fun ownerScore(vs:VIDxSTAKE) = let val (vid,stake) = vs in (vid, ownerAdjustedStakePowerFromStake(vid,stake) + fairnessBoost(vid)) end;

fun battery(vid:int) = if vid = 4 then 20 else if vid = 2 then 55 else 80;
fun bandwidth(vid:int) = if vid = 4 then 25 else if vid = 6 then 50 else 70;
fun latency(vid:int) = if vid = 4 then 90 else if vid = 2 then 65 else 40;
fun availability(vid:int) = if vid = 4 then 35 else if vid = 6 then 70 else 85;
fun capacity(vid:int) = if vid = 4 then 30 else if vid = 2 then 55 else 75;
fun edgeConnectivity(vid:int) = if vid = 4 then 25 else if vid = 6 then 60 else 80;
fun latencyScore(vid:int) = if latency(vid) &gt; 100 then 0 else 100 - latency(vid);
fun mobileFitness(vid:int) = (battery(vid) + bandwidth(vid) + latencyScore(vid) + availability(vid) + capacity(vid) + edgeConnectivity(vid)) div 6;
fun mobileFitnessFromStake(vid:int, stake:int) = if vid = 4 orelse stake &lt;= 35 then 26 else mobileFitness(vid);
fun mobileScore(vs:VIDxSTAKE) = let val (vid,stake) = vs in (vid, mobileFitnessFromStake(vid,stake)) end;
fun mobileOK(msc:VIDxSCORE) = let val (_,s) = msc in s &gt;= MOBILE_FITNESS_MIN end;

fun attackLevel(vid:int) = if vid = 3 then 90 else if vid = 4 then 25 else if vid = 2 then 10 else 0;
fun attackPenalty(vid:int) = attackLevel(vid) div 2;
fun attackLevelFromStake(vid:int, stake:int) = if vid = 3 orelse stake &gt;= 4500 then 90 else if stake &lt;= 35 then 25 else attackLevel(vid);
fun attackPenaltyFromStake(vid:int, stake:int) = attackLevelFromStake(vid,stake) div 2;
fun attackScore(vs:VIDxSTAKE) = let val (vid,stake) = vs in (vid, attackPenaltyFromStake(vid,stake)) end;
fun maliciousScore(asc:VIDxSCORE) = let val (_,p) = asc in p * 2 &gt;= ATTACK_THRESHOLD end;

fun vidOfScore(sc:VIDxSCORE) = let val (vid,_) = sc in vid end;
fun scoreValue(sc:VIDxSCORE) = let val (_,s) = sc in s end;
fun sameVID2(a:VIDxSCORE,b:VIDxSCORE) = vidOfScore(a)=vidOfScore(b);
fun sameVID3(a:VIDxSCORE,b:VIDxSCORE,c:VIDxSCORE) = sameVID2(a,b) andalso sameVID2(a,c);
fun mergeScore(osc:VIDxSCORE, msc:VIDxSCORE, asc:VIDxSCORE) =
  let val vid = vidOfScore(osc)
      val s = scoreValue(osc) + scoreValue(msc) - scoreValue(asc)
  in (vid, clamp0(s)) end;
fun selectionMetric(sc:VIDxSCORE) = let val (vid,s)=sc in (vid,s) end;
fun quarantineMetric(sc:VIDxSCORE) = let val (vid,s)=sc in (100+vid,s) end;
fun lowFitnessMetric(sc:VIDxSCORE) = let val (vid,s)=sc in (200+vid,s) end;
fun eligible(vs:VIDxSTAKE) = let val (_,stake) = vs in stake &gt;= MIN_STAKE end;

fun toShard1(sc:VIDxSCORE) = (1, vidOfScore(sc));
fun toShard2(sc:VIDxSCORE) = (2, vidOfScore(sc));
fun toAudit(sc:VIDxSCORE) = (99, vidOfScore(sc));
fun sidOfCommittee(cm:SIDxVID) = let val (sid,_) = cm in sid end;
fun vidOfCommittee(cm:SIDxVID) = let val (_,vid) = cm in vid end;

fun makeVRFProof(cm:SIDxVID, seed:int) =
  let val (sid,vid) = cm
      val msg = hash4(seed, sid, vid, EPOCH)
      val proof = signMessage(vid,msg)
      val out = posMod(hash3(proof, seed, sid), 100)
  in (sid,vid,seed,out,proof) end;
fun proofToCommittee(pf:VRFPROOF) = let val (sid,vid,_,_,_) = pf in (sid,vid) end;
fun vrfOutput(pf:VRFPROOF) = let val (_,_,_,out,_) = pf in out end;
fun verifyVRFProof(pf:VRFPROOF) =
  let val (sid,vid,seed,out,proof) = pf
      val msg = hash4(seed, sid, vid, EPOCH)
  in proof = signMessage(vid,msg) andalso out = posMod(hash3(proof, seed, sid), 100) end;
fun committeeThreshold(cm:SIDxVID) =
  let val (_,vid) = cm
      val base = VRF_BASE + ownerAdjustedStakePower(vid) + fairnessBoost(vid)
  in if base &gt; VRF_MAX_THRESHOLD then VRF_MAX_THRESHOLD else base end;
fun acceptVRF(pf:VRFPROOF) = verifyVRFProof(pf) andalso vrfOutput(pf) &lt; committeeThreshold(proofToCommittee(pf));
fun rejectVRF(pf:VRFPROOF) = verifyVRFProof(pf) andalso not(acceptVRF(pf));
fun nextSeed(seed:int) = seed + 1;
fun recoveryAccept(pf:VRFPROOF) = verifyVRFProof(pf);
fun vrfMetric(pf:VRFPROOF) = let val (sid,vid,seed,out,_) = pf in (sid, vid*1000 + seed*10 + out) end;
fun rejectMetric(pf:VRFPROOF) = let val (sid,vid,seed,out,_) = pf in (10+sid, vid*1000 + seed*10 + out) end;
fun recoveryMetric(cm:SIDxVID, seed:int) = let val (sid,vid)=cm in (20+sid, vid*100 + nextSeed(seed)) end;

fun shardOfTxID(txid:int) = if txid mod 2 = 1 then 1 else 2;
fun txCommit(txid:int) = (txid, shardOfTxID(txid), hash3(txid, shardOfTxID(txid), EPOCH));
fun cmtTxID(cmt:COMMITMENT) = let val (txid,_,_) = cmt in txid end;
fun cmtShard(cmt:COMMITMENT) = let val (_,sid,_) = cmt in sid end;
fun cmtToShardTx(cmt:COMMITMENT) = (cmtShard(cmt), cmtTxID(cmt));
fun cmtIsShard(cmt:COMMITMENT, sid:int) = cmtShard(cmt) = sid;
fun txRouteMetric(cmt:COMMITMENT) = let val (txid,sid,h)=cmt in (sid, txid + h) end;

fun committeeDistinct(a:SIDxVID,b:SIDxVID) =
  let val (s1,v1)=a
      val (s2,v2)=b
  in s1=s2 andalso v1&lt;&gt;v2 end;
fun sameShardPair(a:SIDxVID,b:SIDxVID,sid:int) = sidOfCommittee(a)=sid andalso sidOfCommittee(b)=sid andalso committeeDistinct(a,b);
fun makeBlockFromTx(tx:SIDxTX, cm:SIDxVID) =
  let val (sid,txid)=tx
      val (_,vid)=cm
  in (sid,txid,vid) end;
fun blockShard(blk:BLOCK) = let val (sid,_,_) = blk in sid end;
fun blockHash(blk:BLOCK) = let val (sid,bid,vid)=blk in hash4(sid,bid,vid,EPOCH) end;
fun blockHashMetric(blk:BLOCK) = let val (sid,_,_) = blk in (30+sid, blockHash(blk)) end;
fun certificateFromQuorum(blk:BLOCK, cm1:SIDxVID, cm2:SIDxVID) =
  let val (sid,bid,_) = blk
      val (_,v1) = cm1
      val (_,v2) = cm2
      val h = hash4(blockHash(blk), v1, v2, sid)
  in (sid,bid,h) end;
fun finalityMetric(cert:CERT) = let val (sid,bid,h)=cert in (40+sid, bid+h) end;
fun receiptFromCert(cert:CERT) = let val (sid,bid,h)=cert in (sid, hash3(h,bid,11)) end;
fun rewardFromCert(cert:CERT) = let val (sid,bid,h)=cert in (sid, 10 + (h mod 7)) end;
fun baselineMetric(seed:int) = (1,77);
fun rrMetric(seed:int) = (2,0);
fun proposedMetric(seed:int) = (3,22);

fun proposerOfBlock(blk:BLOCK) = let val (_,_,vid)=blk in vid end;
fun certificateRewardPool(cert:CERT) = let val (_,_,h)=cert in 12 + (h mod 9) end;
fun mobileRewardBonus(vid:int) = if mobileFitness(vid) &gt;= 70 then 2 else if mobileFitness(vid) &gt;= 60 then 1 else 0;
fun lowStakeRewardBonus(vid:int) = if stakeOfVID(vid) &lt;= 100 then 1 else 0;
fun proposerRewardAmount(cert:CERT, vid:int) = (certificateRewardPool(cert) div 2) + mobileRewardBonus(vid) + lowStakeRewardBonus(vid);
fun voterRewardAmount(cert:CERT, vid:int) = (certificateRewardPool(cert) div 4) + mobileRewardBonus(vid);
fun proposerValidatorReward(blk:BLOCK, cert:CERT) =
  let val vid = proposerOfBlock(blk)
  in (vid, proposerRewardAmount(cert,vid)) end;
fun voterValidatorReward(cm:SIDxVID, cert:CERT) =
  let val (_,vid)=cm
  in (vid, voterRewardAmount(cert,vid)) end;
fun validatorRewardAuditMetric(m:METRIC) = let val (vid,r)=m in (300+vid,r) end;
fun rewardPoolAuditMetric(cert:CERT) = let val (sid,bid,h)=cert in (60+sid, certificateRewardPool(cert)*100 + (h mod 100)) end;

fun rewardVid(m:METRIC) = let val (vid,_) = m in vid end;
fun rewardAmount(m:METRIC) = let val (_,r) = m in r end;
fun sameVIDRewardBalance(m:METRIC, vs:VIDxSTAKE) =
  let val (vid,_) = m
      val (bvid,_) = vs
  in vid = bvid end;
fun updateStakeWithReward(vs:VIDxSTAKE, m:METRIC) =
  let val (vid,bal) = vs
      val (_,r) = m
  in (vid, bal + r) end;
fun ownerRewardShare(m:METRIC) = let val (vid,r)=m in (ownerOf(vid), r) end;
fun validatorRewardShare(m:METRIC) = m;
fun nextEpochStakeAuditMetric(vs:VIDxSTAKE, m:METRIC) =
  let val (vid,bal) = updateStakeWithReward(vs,m)
  in (400+vid, bal) end;
fun ownerRewardAuditMetric(m:METRIC) = let val (oid,r)=ownerRewardShare(m) in (500+oid,r) end;
fun rewardConcentrationAuditMetric(m:METRIC) = let val (vid,r)=m in (600+vid,r) end;

fun rawStakeGiniScaled(seed:int) = (701,84);
fun activePowerGiniScaled(seed:int) = (702,13);
fun rawStakeNakamoto(seed:int) = (711,1);
fun activeValidatorNakamoto(seed:int) = (712,2);
fun rawStakeHHIScaled(seed:int) = (721,83);
fun activeRewardHHIScaled(seed:int) = (722,25);
fun decentralizationMetricBundle(seed:int) =
  1`rawStakeGiniScaled(seed)++
  1`activePowerGiniScaled(seed)++
  1`rawStakeNakamoto(seed)++
  1`activeValidatorNakamoto(seed)++
  1`rawStakeHHIScaled(seed)++
  1`activeRewardHHIScaled(seed);



(* Scenario-generator and multi-epoch experiment support.  RUNCFG fields:
   (runID, epochID, scenarioID, nValidators, nTxs, maliciousMode, weakMobileMode, seed)
   Scenario IDs: 1 balanced, 2 skewed stake, 3 owner stake-splitting, 4 reference high-stake malicious,
                 5 mobile-weak validators, 6 mixed/randomized. *)
fun cfgRun(c:RUNCFG) = let val (r,_,_,_,_,_,_,_) = c in r end;
fun cfgEpoch(c:RUNCFG) = let val (_,e,_,_,_,_,_,_) = c in e end;
fun cfgScenario(c:RUNCFG) = let val (_,_,s,_,_,_,_,_) = c in s end;
fun cfgNValidators(c:RUNCFG) = let val (_,_,_,nv,_,_,_,_) = c in nv end;
fun cfgNTxs(c:RUNCFG) = let val (_,_,_,_,nt,_,_,_) = c in nt end;
fun cfgMaliciousMode(c:RUNCFG) = let val (_,_,_,_,_,am,_,_) = c in am end;
fun cfgWeakMode(c:RUNCFG) = let val (_,_,_,_,_,_,wm,_) = c in wm end;
fun cfgSeed(c:RUNCFG) = let val (_,_,_,_,_,_,_,sd) = c in sd end;

fun deterministicNoise(c:RUNCFG, vid:int) = posMod(cfgRun(c)*97 + cfgEpoch(c)*43 + cfgScenario(c)*31 + vid*53, 97);
fun genStake(c:RUNCFG, vid:int) =
  let val s = cfgScenario(c)
      val noise = deterministicNoise(c,vid)
  in
    if s = 1 then 100 + noise
    else if s = 2 then (if vid = 3 then 5000 + noise else 30 + (noise mod 180))
    else if s = 3 then (if vid = 1 orelse vid = 2 then 2500 + noise else 40 + (noise mod 160))
    else if s = 4 then
      (if vid = 1 then 100 else if vid = 2 then 200 else if vid = 3 then 5000 else if vid = 4 then 30 else if vid = 5 then 80 else if vid = 6 then 70 else 10 + noise)
    else if s = 5 then (if vid = 4 orelse vid = 5 then 25 + (noise mod 10) else 80 + noise)
    else 10 + posMod(cfgRun(c)*vid*37 + cfgEpoch(c)*19 + noise, 5000)
  end;

fun oneValidator(c:RUNCFG, vid:int) = if vid &lt;= cfgNValidators(c) then 1`(vid, genStake(c,vid)) else empty;
fun genValidators(c:RUNCFG) =
  oneValidator(c,1)++oneValidator(c,2)++oneValidator(c,3)++oneValidator(c,4)++oneValidator(c,5)++oneValidator(c,6)++
  oneValidator(c,7)++oneValidator(c,8)++oneValidator(c,9)++oneValidator(c,10)++oneValidator(c,11)++oneValidator(c,12);

fun genTxID(c:RUNCFG, idx:int) = 100 + ((cfgRun(c)-1)*1000) + ((cfgEpoch(c)-1)*100) + idx;
fun oneTx(c:RUNCFG, idx:int) = if idx &lt;= cfgNTxs(c) then 1`genTxID(c,idx) else empty;
fun genMobileTxs(c:RUNCFG) =
  oneTx(c,1)++oneTx(c,2)++oneTx(c,3)++oneTx(c,4)++oneTx(c,5)++oneTx(c,6)++oneTx(c,7)++oneTx(c,8)++oneTx(c,9)++oneTx(c,10)++
  oneTx(c,11)++oneTx(c,12)++oneTx(c,13)++oneTx(c,14)++oneTx(c,15)++oneTx(c,16)++oneTx(c,17)++oneTx(c,18)++oneTx(c,19)++oneTx(c,20)++
  oneTx(c,21)++oneTx(c,22)++oneTx(c,23)++oneTx(c,24)++oneTx(c,25)++oneTx(c,26)++oneTx(c,27)++oneTx(c,28)++oneTx(c,29)++oneTx(c,30)++
  oneTx(c,31)++oneTx(c,32)++oneTx(c,33)++oneTx(c,34)++oneTx(c,35)++oneTx(c,36)++oneTx(c,37)++oneTx(c,38)++oneTx(c,39)++oneTx(c,40)++
  oneTx(c,41)++oneTx(c,42)++oneTx(c,43)++oneTx(c,44)++oneTx(c,45)++oneTx(c,46)++oneTx(c,47)++oneTx(c,48)++oneTx(c,49)++oneTx(c,50);

fun genEpochSeed(c:RUNCFG) = cfgSeed(c) + ((cfgRun(c)-1)*13) + ((cfgEpoch(c)-1)*17);
fun genBaselineSeed(c:RUNCFG) = cfgScenario(c);
fun scenarioRunMetric(c:RUNCFG) = (1000 + cfgScenario(c), cfgRun(c)*100 + cfgEpoch(c));
fun scenarioValidatorCountMetric(c:RUNCFG) = (1010, cfgNValidators(c));
fun scenarioTxCountMetric(c:RUNCFG) = (1011, cfgNTxs(c));
fun scenarioSeedMetric(c:RUNCFG) = (1012, genEpochSeed(c));
fun genScenarioRunLog(c:RUNCFG) =
  1`scenarioRunMetric(c)++1`scenarioValidatorCountMetric(c)++1`scenarioTxCountMetric(c)++1`scenarioSeedMetric(c);

fun slashPenalty(vid:int) = if vid = 3 then 50 else if vid = 4 then 5 else 10;
fun doubleProposalEvidence(sc:VIDxSCORE) = let val (vid,s)=sc in (800+vid,s) end;
fun invalidVoteEvidence(sc:VIDxSCORE) = let val (vid,s)=sc in (820+vid,s) end;
fun offlineMobileEvidence(sc:VIDxSCORE) = let val (vid,s)=sc in (840+vid,s) end;
fun doubleProposalSlash(sc:VIDxSCORE) = let val (vid,_) = sc in (900+vid, slashPenalty(vid)) end;
fun invalidVoteSlash(sc:VIDxSCORE) = let val (vid,_) = sc in (920+vid, slashPenalty(vid)) end;
fun offlineMobilePenalty(sc:VIDxSCORE) = let val (vid,_) = sc in (940+vid, slashPenalty(vid)) end;</layout>
          </ml>
        </block>
      </block>
    </globbox>
